# Mchanga Afya — frontend environment variables
# Copy to .env and fill in actual values.

# Backend API base URL. Default for local dev is http://localhost:4000
VITE_API_BASE=http://localhost:4000

# Optional: external admin hub (used by admin-role login redirect)
VITE_ADMIN_HUB_URL=https://mchanga-akili-hub-main-cr6a.vercel.app/admin
